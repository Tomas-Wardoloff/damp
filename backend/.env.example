APP_NAME=Livestock Health API
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/livestock
AI_SERVICE_URL=https://damp-machine-learning.onrender.com

HEALTH_WINDOW_SIZE=5
HEALTH_SCHEDULER_ENABLED=true
HEALTH_SCHEDULER_CYCLE_MINUTES=60
AUTO_CREATE_TABLES=true
